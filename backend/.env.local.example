# Backend Development Environment
# Copy .env.example to .env and update with your values

# For local development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=DEBUG

# Development is usually fine with these defaults
TORCH_NUM_THREADS=2
HF_HOME=/app/.cache

# Groq Chat (set your own key in backend/.env)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Chat pipeline services
UPSTREAM_API_URL=https://cainebenoy-bhashadocs-inbound-api.hf.space/api/translate-inbound
DOWNSTREAM_API_URL=https://cainebenoy-bhashadocs-api.hf.space/api/translate-text
REQUEST_TIMEOUT_SECONDS=120

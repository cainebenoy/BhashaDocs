# Backend Configuration

# CORS Origins - Restrict to your production domain(s)
# For local development: http://localhost:3000
# For production: https://bhasha-docs.vercel.app
CORS_ORIGINS=https://bhasha-docs.vercel.app,http://localhost:3000

# API Configuration
# Max file upload size in bytes (50MB)
MAX_FILE_SIZE=52428800

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Model Configuration
# Number of threads for PyTorch (reduce for low-memory systems)
TORCH_NUM_THREADS=2

# Hugging Face Model Configuration
HF_HOME=/app/.cache

# Groq Configuration
# Set this in your real .env file. Do not commit secrets.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Chat pipeline translation services
UPSTREAM_API_URL=https://cainebenoy-bhashadocs-inbound-api.hf.space/api/translate-inbound
DOWNSTREAM_API_URL=https://cainebenoy-bhashadocs-api.hf.space/api/translate-text

# Outbound request timeout for chat orchestration (seconds)
REQUEST_TIMEOUT_SECONDS=120

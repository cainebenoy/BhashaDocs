# Backend Configuration

# CORS Origins - Restrict to your production domain(s)
# For local development: http://localhost:3000
# For production: https://bhasha-docs.vercel.app
CORS_ORIGINS=https://bhasha-docs.vercel.app,http://localhost:3000

# API Configuration
# Max file upload size in bytes (50MB)
MAX_FILE_SIZE=52428800

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Model Configuration
# Number of threads for PyTorch (reduce for low-memory systems)
TORCH_NUM_THREADS=2

# Hugging Face Model Configuration
HF_HOME=/app/.cache
